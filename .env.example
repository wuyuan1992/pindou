# ─────────────────────────────────────────────────────────────
# 高德地图开放平台凭证
# ─────────────────────────────────────────────────────────────
# 申请地址：https://lbs.amap.com/dev/key/app
# 服务平台选「Web 端（JSAPI）」，创建后会同时得到 Key 和安全密钥
#
# 本地开发：把下面的值填到 .env.local（不要提交到 git）
# Vercel 部署：在项目 Settings → Environment Variables 中添加
#
# 注意：2021-12-02 之后申请的 key 必须同时配置安全密钥（securityJsCode），
#       否则 JS API 加载会报 INVALID_USER_SCODE。

VITE_AMAP_KEY=
VITE_AMAP_SECURITY_CODE=


# ─────────────────────────────────────────────────────────────
# 线下门店信息（门店弹窗组件展示 + 导航目的地）
# ─────────────────────────────────────────────────────────────

# 展示名：用作 marker title 和 navigation URI 的目的地名称
VITE_STORE_NAME=拼豆 Pindou · 线下门店

# 详细地址（信息卡「地址」一栏显示的文字）
VITE_STORE_ADDRESS=上海市杨浦区绿地双创中心（国霞路东）国航路30号

# 营业时间（信息卡「营业时间」一栏）
VITE_STORE_HOURS=每日 10:00 – 22:00

# 咨询电话（信息卡「咨询电话」一栏）
VITE_STORE_PHONE=021-0000-0000

# PlaceSearch 关键词：用于精确定位门店坐标（避免硬编码坐标偏差）
# 建议填 POI 名（如「绿地双创中心」），配合 CITY 字段限定城市
VITE_STORE_SEARCH_KEYWORD=绿地双创中心

# PlaceSearch 限定城市（中文名，如「上海」）
VITE_STORE_SEARCH_CITY=上海

# Fallback 经纬度（PlaceSearch 失败 / 无 key 时使用）
# 拾取器：https://lbs.amap.com/tools/picker
VITE_STORE_LNG=121.5137
VITE_STORE_LAT=31.2655
